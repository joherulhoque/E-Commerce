            //         Nav.NavigateTo("/Product");
            //         break;
            //     case "POS":
            //         Nav.NavigateTo("/POS");
            //         break;
            //     case "Accountant":
            //         Nav.NavigateTo("/Cash");
            //         break;
            //     default:
            //         // Invalid role
            //         break;
            // }
        }
        else
        {
            // Show login failed message
        }
    }
}
