@using BlazorBootstrap

@using SuperShop.Models
@using SuperShop.Services

@using BlazorBootstrap.Components



@inject UserService UserService
@inject NavigationManager Nav


@rendermode InteractiveServer



 <div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">SuperShop</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
         @if (UserService.Role == "SuperAdmin")
        {
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Shop">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Shop
            </NavLink>
        </div>

         <div class="nav-item px-3">
            <NavLink class="nav-link" href="Subscription">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Subscription
            </NavLink>
        </div>
        }
        @if (UserService.Role == "ShopAdmin")
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Product">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Product
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Purchase">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Purchase
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Stock">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Stock
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Sales">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Sales
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Staff">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Staff
                </NavLink>
            </div>
        }
        @if (UserService.Role == "POS")
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="POS">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> POS
                </NavLink>
            </div>
          
        }
        @if (UserService.Role == "Accountant")
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Cash">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Cash
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Bank">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Bank
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="Ledger">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Ledger
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="profitloss">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> profitloss
                </NavLink>
            </div>

        }
        <div class="nav-item px-3">
             <NavLink class="nav-link" href="" @onclick="Logout">
              
               <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Logout
             
                </NavLink> 
         
        </div>
       
    </nav>

</div> 
 

@code {
    void Logout()
    {
        UserService.Logout();
        Nav.NavigateTo("/", true);

        StateHasChanged();
    }
}
 
